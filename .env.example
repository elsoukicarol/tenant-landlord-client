# Base URL of the Habitare backend. On a simulator pointed at a dev box on the
# same LAN, use the host's LAN IP (not localhost) so the simulator can resolve
# it — e.g. http://192.168.1.42:3000/api/v1
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# `development` | `staging` | `production`
EXPO_PUBLIC_ENVIRONMENT=development

# EAS projectId for expo-notifications.getExpoPushTokenAsync(). Also set in
# app.json under `expo.extra.eas.projectId`. Obtain it from
# https://expo.dev after running `eas init`.
EXPO_PUBLIC_EAS_PROJECT_ID=
