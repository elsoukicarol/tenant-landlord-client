{
  "expo": {
    "name": "Habitare",
    "slug": "habitare",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "habitare",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F1EC"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.habitare.mobile",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Habitare needs access to your photos so you can attach them to maintenance requests.",
        "NSCameraUsageDescription": "Habitare needs camera access so you can photograph maintenance issues."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F4F1EC"
      },
      "package": "app.habitare.mobile",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Habitare needs access to your photos so you can attach them to maintenance requests.",
          "cameraPermission": "Habitare needs camera access so you can photograph maintenance issues."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#E8502A"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
